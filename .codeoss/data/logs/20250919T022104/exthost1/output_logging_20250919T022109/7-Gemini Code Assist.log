I0919 02:24:01.365997    1834 server.go:641] jsonrpc2: --> notif: textDocument/didSave: {"textDocument":{"uri":"file:///home/itzarbabali/lie-lens-frontend/style.css"},"text":"/* Mindful Compass - Modern Frontend Styling */\n/* CSS Variables for consistent theming */\n:root {\n  /* Color Palette */\n  --primary-color: #2563eb;\n  --primary-dark: #1d4ed8;\n  --primary-light: #3b82f6;\n  --secondary-color: #10b981;\n  --accent-color: #f59e0b;\n  --warning-color: #ef4444;\n  --success-color: #10b981;\n\n  /* Risk Level Colors */\n  --risk-low: #10b981;\n  --risk-medium: #f59e0b;\n  --risk-high: #ef4444;\n  --risk-critical: #dc2626;\n\n  /* Neutral Colors */\n  --gray-50: #f9fafb;\n  --gray-100: #f3f4f6;\n  --gray-200: #e5e7eb;\n  --gray-300: #d1d5db;\n  --gray-400: #9ca3af;\n  --gray-500: #6b7280;\n  --gray-600: #4b5563;\n  --gray-700: #374151;\n  --gray-800: #1f2937;\n  --gray-900: #111827;\n\n  /* Typography */\n  --font-family: 'Inter', system-ui, -apple-system, sans-serif;\n  --font-size-xs: 0.75rem;\n  --font-size-sm: 0.875rem;\n  --font-size-base: 1rem;\n  --font-size-lg: 1.125rem;\n  --font-size-xl: 1.25rem;\n  --font-size-2xl: 1.5rem;\n  --font-size-3xl: 1.875rem;\n  --font-size-4xl: 2.25rem;\n\n  /* Spacing */\n  --spacing-1: 0.25rem;\n  --spacing-2: 0.5rem;\n  --spacing-3: 0.75rem;\n  --spacing-4: 1rem;\n  --spacing-5: 1.25rem;\n  --spacing-6: 1.5rem;\n  --spacing-8: 2rem;\n  --spacing-10: 2.5rem;\n  --spacing-12: 3rem;\n  --spacing-16: 4rem;\n\n  /* Border Radius */\n  --radius-sm: 0.375rem;\n  --radius-base: 0.5rem;\n  --radius-lg: 0.75rem;\n  --radius-xl: 1rem;\n  --radius-full: 9999px;\n\n  /* Shadows */\n  --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);\n  --shadow-base: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);\n  --shadow-lg: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);\n  --shadow-xl: 0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1);\n}\n\n/* Reset and Base Styles */\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nbody {\n  font-family: var(--font-family);\n  font-size: var(--font-size-base);\n  line-height: 1.6;\n  color: var(--gray-800);\n  background: linear-gradient(135deg, #f8faff 0%, #e8f4ff 100%);\n  min-height: 100vh;\n}\n\n.container {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 0 var(--spacing-4);\n}\n\n/* Utility Classes */\n.hidden {\n  display: none !important;\n}\n\n.text-center {\n  text-align: center;\n}\n\n.font-bold {\n  font-weight: 600;\n}\n\n/* Header Styles */\n.header {\n  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);\n  color: white;\n  padding: var(--spacing-8) 0;\n  box-shadow: var(--shadow-lg);\n}\n\n.brand {\n  text-align: center;\n}\n\n.logo {\n  font-size: var(--font-size-4xl);\n  margin-bottom: var(--spacing-4);\n}\n\n.logo i {\n  color: var(--accent-color);\n  filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));\n}\n\n.brand h1 {\n  font-size: var(--font-size-3xl);\n  font-weight: 700;\n  margin-bottom: var(--spacing-2);\n}\n\n.tagline {\n  font-size: var(--font-size-lg);\n  opacity: 0.9;\n  font-weight: 300;\n}\n\n/* Main Content */\n.main {\n  padding: var(--spacing-12) 0;\n}\n\n/* Hero Section */\n.hero {\n  text-align: center;\n  margin-bottom: var(--spacing-12);\n}\n\n.hero h2 {\n  font-size: var(--font-size-3xl);\n  font-weight: 600;\n  color: var(--gray-900);\n  margin-bottom: var(--spacing-4);\n  line-height: 1.2;\n}\n\n.hero-description {\n  font-size: var(--font-size-lg);\n  color: var(--gray-600);\n  max-width: 600px;\n  margin: 0 auto;\n}\n\n/* Input Section */\n.input-section {\n  margin-bottom: var(--spacing-16);\n}\n\n.input-card {\n  background: white;\n  border-radius: var(--radius-xl);\n  padding: var(--spacing-8);\n  box-shadow: var(--shadow-xl);\n  border: 1px solid var(--gray-200);\n}\n\n.form-group {\n  margin-bottom: var(--spacing-6);\n}\n\n.form-label {\n  display: flex;\n  align-items: center;\n  font-weight: 500;\n  color: var(--gray-700);\n  margin-bottom: var(--spacing-3);\n  font-size: var(--font-size-lg);\n}\n\n.form-label i {\n  margin-right: var(--spacing-2);\n  color: var(--primary-color);\n}\n\n.content-input {\n  width: 100%;\n  padding: var(--spacing-4);\n  border: 2px solid var(--gray-300);\n  border-radius: var(--radius-lg);\n  font-family: var(--font-family);\n  font-size: var(--font-size-base);\n  line-height: 1.5;\n  resize: vertical;\n  transition: all 0.2s ease;\n  background: var(--gray-50);\n}\n\n.content-input:focus {\n  outline: none;\n  border-color: var(--primary-color);\n  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);\n  background: white;\n}\n\n.content-input::placeholder {\n  color: var(--gray-400);\n}\n\n.form-actions {\n  text-align: center;\n}\n\n.analyze-btn {\n  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%);\n  color: white;\n  border: none;\n  padding: var(--spacing-4) var(--spacing-8);\n  border-radius: var(--radius-full);\n  font-size: var(--font-size-lg);\n  font-weight: 600;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  box-shadow: var(--shadow-lg);\n  position: relative;\n  min-width: 200px;\n  min-height: 56px;\n}\n\n.analyze-btn:hover:not(:disabled) {\n  transform: translateY(-2px);\n  box-shadow: var(--shadow-xl);\n}\n\n.analyze-btn:disabled {\n  cursor: not-allowed;\n  opacity: 0.7;\n}\n\n.btn-loading {\n  display: none;\n}\n\n.analyze-btn.loading .btn-text {\n  display: none;\n}\n\n.analyze-btn.loading .btn-loading {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  gap: var(--spacing-2);\n}\n\n/* Results Section */\n.results-section {\n  animation: slideInUp 0.6s ease-out;\n}\n\n@keyframes slideInUp {\n  from {\n    opacity: 0;\n    transform: translateY(30px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n.results-container {\n  display: grid;\n  gap: var(--spacing-6);\n}\n\n/* Report Cards */\n.report-card {\n  background: white;\n  border-radius: var(--radius-xl);\n  box-shadow: var(--shadow-lg);\n  border: 1px solid var(--gray-200);\n  overflow: hidden;\n  transition: all 0.3s ease;\n}\n\n.report-card:hover {\n  transform: translateY(-2px);\n  box-shadow: var(--shadow-xl);\n}\n\n.card-header {\n  background: linear-gradient(135deg, var(--gray-50) 0%, var(--gray-100) 100%);\n  padding: var(--spacing-5) var(--spacing-6);\n  border-bottom: 1px solid var(--gray-200);\n}\n\n.card-header h3 {\n  font-size: var(--font-size-xl);\n  font-weight: 600;\n  color: var(--gray-800);\n  display: flex;\n  align-items: center;\n  gap: var(--spacing-3);\n}\n\n.card-header i {\n  color: var(--primary-color);\n}\n\n.card-subtitle {\n  color: var(--gray-600);\n  margin-top: var(--spacing-2);\n  font-size: var(--font-size-sm);\n}\n\n.card-content {\n  padding: var(--spacing-6);\n}\n\n/* Summary Card */\n.summary-card {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: var(--spacing-6);\n}\n\n@media (max-width: 768px) {\n  .summary-card {\n    grid-template-columns: 1fr;\n  }\n}\n\n.risk-indicator {\n  display: flex;\n  align-items: center;\n  gap: var(--spacing-4);\n  margin-bottom: var(--spacing-6);\n}\n\n.risk-badge {\n  display: flex;\n  align-items: center;\n  gap: var(--spacing-2);\n  padding: var(--spacing-2) var(--spacing-4);\n  border-radius: var(--radius-full);\n  font-weight: 600;\n  font-size: var(--font-size-sm);\n  text-transform: uppercase;\n}\n\n.risk-badge.low {\n  background: rgba(16, 185, 129, 0.1);\n  color: var(--risk-low);\n  border: 1px solid rgba(16, 185, 129, 0.2);\n}\n\n.risk-badge.medium {\n  background: rgba(245, 158, 11, 0.1);\n  color: var(--risk-medium);\n  border: 1px solid rgba(245, 158, 11, 0.2);\n}\n\n.risk-badge.high {\n  background: rgba(239, 68, 68, 0.1);\n  color: var(--risk-high);\n  border: 1px solid rgba(239, 68, 68, 0.2);\n}\n\n.risk-badge.critical {\n  background: rgba(220, 38, 38, 0.1);\n  color: var(--risk-critical);\n  border: 1px solid rgba(220, 38, 38, 0.2);\n}\n\n.risk-score {\n  text-align: center;\n}\n\n.score-circle {\n  width: 80px;\n  height: 80px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-weight: 700;\n  font-size: var(--font-size-2xl);\n  color: white;\n  position: relative;\n  overflow: hidden;\n  margin: 0 auto;\n}\n\n.score-circle::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: conic-gradient(from 0deg, var(--primary-color) 0% var(--score-percentage, 0%), var(--gray-200) var(--score-percentage, 0%) 100%);\n  border-radius: 50%;\n}\n\n.score-circle span {\n  position: relative;\n  z-index: 1;\n  background: white;\n  width: 60px;\n  height: 60px;\n  border-radius: 50%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: var(--gray-800);\n}\n\n.score-label {\n  font-size: var(--font-size-sm);\n  color: var(--gray-600);\n  margin-top: var(--spacing-2);\n}\n\n.credibility-rating {\n  display: flex;\n  flex-direction: column;\n  gap: var(--spacing-2);\n}\n\n.rating-label {\n  font-size: var(--font-size-sm);\n  color: var(--gray-600);\n}\n\n.rating-value {\n  padding: var(--spacing-2) var(--spacing-3);\n  border-radius: var(--radius-base);\n  font-weight: 600;\n  font-size: var(--font-size-sm);\n  text-transform: uppercase;\n}\n\n.rating-value.reliable {\n  background: rgba(16, 185, 129, 0.1);\n  color: var(--success-color);\n  border: 1px solid rgba(16, 185, 129, 0.2);\n}\n\n.rating-value.questionable {\n  background: rgba(245, 158, 11, 0.1);\n  color: var(--accent-color);\n  border: 1px solid rgba(245, 158, 11, 0.2);\n}\n\n.rating-value.unreliable {\n  background: rgba(239, 68, 68, 0.1);\n  color: var(--warning-color);\n  border: 1px solid rgba(239, 68, 68, 0.2);\n}\n\n.rating-value.fabricated {\n  background: rgba(220, 38, 38, 0.1);\n  color: var(--risk-critical);\n  border: 1px solid rgba(220, 38, 38, 0.2);\n}\n\n.primary-concern h4 {\n  font-size: var(--font-size-lg);\n  margin-bottom: var(--spacing-3);\n  color: var(--gray-800);\n}\n\n.primary-concern p {\n  font-size: var(--font-size-base);\n  color: var(--gray-600);\n}\n\n/* Tactics Card */\n.tactics-card .card-content {\n  padding: var(--spacing-6);\n}\n\n.tactics-list {\n  display: grid;\n  gap: var(--spacing-4);\n}\n\n.tactic-item {\n  padding: var(--spacing-4);\n  border: 1px solid var(--gray-200);\n  border-radius: var(--radius-lg);\n  background: var(--gray-50);\n}\n\n.tactic-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  margin-bottom: var(--spacing-3);\n}\n\n.tactic-name {\n  font-weight: 600;\n  color: var(--gray-800);\n  font-size: var(--font-size-lg);\n}\n\n.manipulation-type {\n  padding: var(--spacing-1) var(--spacing-3);\n  border-radius: var(--radius-full);\n  font-size: var(--font-size-xs);\n  font-weight: 600;\n  text-transform: uppercase;\n}\n\n.manipulation-type.emotional {\n  background: rgba(239, 68, 68, 0.1);\n  color: var(--warning-color);\n}\n\n.manipulation-type.logical {\n  background: rgba(59, 130, 246, 0.1);\n  color: var(--primary-color);\n}\n\n.manipulation-type.social {\n  background: rgba(16, 185, 129, 0.1);\n  color: var(--success-color);\n}\n\n.manipulation-type.authority {\n  background: rgba(245, 158, 11, 0.1);\n  color: var(--accent-color);\n}\n\n.tactic-description {\n  color: var(--gray-600);\n  margin-bottom: var(--spacing-3);\n}\n\n.tactic-example {\n  background: white;\n  padding: var(--spacing-3);\n  border-radius: var(--radius-base);\n  border-left: 4px solid var(--primary-color);\n  font-style: italic;\n  color: var(--gray-700);\n}\n\n/* Biases Card */\n.biases-list {\n  display: grid;\n  gap: var(--spacing-5);\n}\n\n.bias-item {\n  padding: var(--spacing-5);\n  border: 1px solid var(--gray-200);\n  border-radius: var(--radius-lg);\n  background: linear-gradient(135deg, #fefefe 0%, #f9f9f9 100%);\n}\n\n.bias-header {\n  margin-bottom: var(--spacing-4);\n}\n\n.bias-header h4 {\n  font-size: var(--font-size-lg);\n  color: var(--primary-color);\n  margin-bottom: var(--spacing-2);\n}\n\n.bias-header p {\n  color: var(--gray-600);\n}\n\n.resistance-tip {\n  margin-top: var(--spacing-4);\n  font-style: italic;\n  color: var(--success-color);\n  font-weight: 500;\n}\n\n/* Insights Card */\n.insights-grid {\n  display: grid;\n  gap: var(--spacing-4);\n  margin-bottom: var(--spacing-6);\n}\n\n.insight-item h4 {\n  font-size: var(--font-size-base);\n  font-weight: 600;\n  color: var(--primary-dark);\n  display: flex;\n  align-items: center;\n  gap: var(--spacing-2);\n  margin-bottom: var(--spacing-2);\n}\n\n.insights-grid p {\n  color: var(--gray-600);\n  font-size: var(--font-size-sm);\n}\n\n.questions-section, .verification-section {\n  margin-bottom: var(--spacing-6);\n}\n\n.questions-section h4, .verification-section h4 {\n  font-size: var(--font-size-lg);\n  font-weight: 600;\n  color: var(--primary-color);\n  display: flex;\n  align-items: center;\n  gap: var(--spacing-2);\n  margin-bottom: var(--spacing-4);\n}\n\n.questions-list, .verification-list {\n  padding-left: var(--spacing-6);\n  color: var(--gray-600);\n}\n\n.questions-list li, .verification-list li {\n  margin-bottom: var(--spacing-2);\n}\n\n/* Fact Check Flags */\n.flags-card {\n  border-left: 4px solid var(--warning-color);\n}\n\n.flags-card .card-header i {\n  color: var(--warning-color);\n}\n\n.flags-list {\n  display: grid;\n  gap: var(--spacing-4);\n}\n\n.flag-item {\n  background: var(--gray-50);\n  padding: var(--spacing-4);\n  border: 1px solid var(--warning-color);\n  border-radius: var(--radius-lg);\n}\n\n.flag-claim {\n  font-weight: 600;\n  font-size: var(--font-size-lg);\n  color: var(--warning-color);\n  margin-bottom: var(--spacing-2);\n}\n\n.flag-reason {\n  font-size: var(--font-size-sm);\n  color: var(--gray-600);\n}\n\n/* Recommendations Card */\n.recommendations-card {\n  border-left: 4px solid var(--secondary-color);\n}\n\n.recommendations-card .card-header i {\n  color: var(--secondary-color);\n}\n\n.recommendation-grid {\n  display: grid;\n  gap: var(--spacing-4);\n  margin-bottom: var(--spacing-6);\n}\n\n.recommendation-item h4 {\n  font-size: var(--font-size-base);\n  font-weight: 600;\n  color: var(--secondary-color);\n  display: flex;\n  align-items: center;\n  gap: var(--spacing-2);\n  margin-bottom: var(--spacing-2);\n}\n\n.share-decision {\n  display: flex;\n  align-items: center;\n  gap: var(--spacing-2);\n}\n\n.share-decision .decision-badge {\n  padding: var(--spacing-2) var(--spacing-4);\n  border-radius: var(--radius-full);\n  font-weight: 600;\n  font-size: var(--font-size-sm);\n  text-transform: uppercase;\n}\n\n.share-decision.safe .decision-badge {\n  background: rgba(16, 185, 129, 0.1);\n  color: var(--success-color);\n  border: 1px solid rgba(16, 185, 129, 0.2);\n}\n\n.share-decision.context .decision-badge {\n  background: rgba(245, 158, 11, 0.1);\n  color: var(--accent-color);\n  border: 1px solid rgba(245, 158, 11, 0.2);\n}\n\n.share-decision.avoid .decision-badge {\n  background: rgba(239, 68, 68, 0.1);\n  color: var(--warning-color);\n  border: 1px solid rgba(239, 68, 68, 0.2);\n}\n\n.share-decision.do-not-share .decision-badge {\n  background: rgba(220, 38, 38, 0.1);\n  color: var(--risk-critical);\n  border: 1px solid rgba(220, 38, 38, 0.2);\n}\n\n/* Metrics Card */\n.metrics-card {\n  border-left: 4px solid var(--primary-light);\n}\n\n.metrics-card .card-header i {\n  color: var(--primary-light);\n}\n\n.confidence-grid {\n  display: grid;\n  gap: var(--spacing-6);\n}\n\n.confidence-item label {\n  font-size: var(--font-size-sm);\n  color: var(--gray-600);\n  margin-bottom: var(--spacing-2);\n  display: block;\n}\n\n.confidence-bar {\n  background: var(--gray-200);\n  height: 10px;\n  border-radius: var(--radius-full);\n  position: relative;\n}\n\n.confidence-fill {\n  background: var(--primary-color);\n  height: 100%;\n  border-radius: var(--radius-full);\n  width: 0%;\n  transition: width 0.6s ease;\n}\n\n.confidence-item span {\n  position: absolute;\n  top: 50%;\n  right: var(--spacing-2);\n  transform: translateY(-50%);\n  font-size: var(--font-size-xs);\n  color: white;\n  font-weight: 600;\n}\n\n.context-badge {\n  padding: var(--spacing-1) var(--spacing-3);\n  border-radius: var(--radius-full);\n  font-size: var(--font-size-xs);\n  font-weight: 600;\n  text-transform: uppercase;\n  background: rgba(59, 130, 246, 0.1);\n  color: var(--primary-color);\n  border: 1px solid rgba(59, 130, 246, 0.2);\n}\n\n/* Action Buttons */\n.action-buttons {\n  display: flex;\n  gap: var(--spacing-4);\n  justify-content: center;\n  margin-top: var(--spacing-8);\n}\n\n.secondary-btn, .primary-btn {\n  border: none;\n  padding: var(--spacing-4) var(--spacing-8);\n  border-radius: var(--radius-full);\n  font-size: var(--font-size-lg);\n  font-weight: 600;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  box-shadow: var(--shadow-base);\n}\n\n.secondary-btn {\n  background: white;\n  color: var(--primary-color);\n  border: 2px solid var(--primary-color);\n}\n\n.primary-btn {\n  background: var(--primary-color);\n  color: white;\n  border: 2px solid var(--primary-color);\n}\n\n/* Error Section */\n.error-section {\n  text-align: center;\n  padding: var(--spacing-12);\n}\n\n.error-card {\n  background: var(--gray-50);\n  border-radius: var(--radius-xl);\n  box-shadow: var(--shadow-xl);\n  padding: var(--spacing-12);\n  border: 1px solid var(--warning-color);\n}\n\n.error-icon {\n  font-size: var(--font-size-4xl);\n  color: var(--warning-color);\n  margin-bottom: var(--spacing-6);\n}\n\n.error-section h3 {\n  font-size: var(--font-size-3xl);\n  color: var(--gray-800);\n  margin-bottom: var(--spacing-4);\n}\n\n.error-section p {\n  color: var(--gray-600);\n  margin-bottom: var(--spacing-8);\n}\n\n.retry-btn {\n  background: var(--primary-color);\n  color: white;\n  border: none;\n  padding: var(--spacing-4) var(--spacing-8);\n  border-radius: var(--radius-full);\n  font-size: var(--font-size-lg);\n  font-weight: 600;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  box-shadow: var(--shadow-lg);\n}\n\n/* Loading Overlay */\n.loading-overlay {\n  position: fixed;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  background: rgba(255, 255, 255, 0.9);\n  backdrop-filter: blur(5px);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  z-index: 1000;\n  flex-direction: column;\n  text-align: center;\n  transition: opacity 0.3s ease;\n}\n\n.loading-spinner {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: var(--spacing-4);\n  padding: var(--spacing-8);\n  background: white;\n  border-radius: var(--radius-xl);\n  box-shadow: var(--shadow-xl);\n}\n\n.spinner-ring {\n  width: 50px;\n  height: 50px;\n  border: 5px solid var(--gray-200);\n  border-top: 5px solid var(--primary-color);\n  border-radius: 50%;\n  animation: spin 1s linear infinite;\n}\n\n@keyframes spin {\n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n\n.loading-spinner h3 {\n  font-size: var(--font-size-xl);\n  color: var(--primary-color);\n  margin-top: var(--spacing-4);\n}\n\n.loading-spinner p {\n  color: var(--gray-600);\n}"}
